{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "outDir": "static",
    "rootDir": "src",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
